{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.git/**",
      "**/node_modules/**",
      "dejiina_agent/**",
      "scripts/**",
      "**/*.md",
      "**/*.docx",
      "**/*.xlsx",
      "**/*.js",
      "**/*.mjs",
      "**/*.bat",
      "printquote/**",
      "meishi-order/**",
      "workers/**",
      "research/**",
      "output/**",
      "33_SNSハーネス/**",
      "開発環境1/**"
    ],
    "rewrites": [
      { "source": "/kakeibo",        "destination": "/kakeibo.html" },
      { "source": "/manga",          "destination": "/manga.html" },
      { "source": "/manga-list",     "destination": "/manga-public.html" },
      { "source": "/bucket-list",    "destination": "/bucket-list.html" }
    ],
    "cleanUrls": true
  },
  "database": {
    "rules": "database.rules.json"
  }
}
