// PrintQuote Prisma Schema
// DB: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── ENUM ────────────────────────────────────────────────────

enum UserRole {
  admin
  staff
}

enum ProductType {
  thick
  thin
}

enum EstimateStatus {
  draft
  issued
  approved
  rejected
  expired
}

enum CoaterType {
  none
  single
  double
}

enum ColorType {
  process
  special
}

enum ProcessType {
  cutting
  press
  pp
  emboss
  foil
  lamination
  corrugated
  thomson
  binding
  packing
  delivery
  other
}

enum MoldType {
  thomson
  foil
  emboss
  other
}

// ── マスタ ───────────────────────────────────────────────────

model Paper {
  id           Int       @id @default(autoincrement())
  number       Int       @unique
  name         String    @db.VarChar(100)
  parentSize   String    @db.VarChar(30)    @map("parent_size")
  widthMm      Decimal   @db.Decimal(7, 1)  @map("width_mm")
  heightMm     Decimal   @db.Decimal(7, 1)  @map("height_mm")
  reamWeight   Decimal?  @db.Decimal(6, 2)  @map("ream_weight")
  unitPrice    Decimal   @db.Decimal(10, 2) @map("unit_price")
  lowVolPrice  Decimal?  @db.Decimal(10, 2) @map("low_vol_price")
  rate         Decimal   @db.Decimal(5, 2)  @default(100)
  supplier     String?   @db.VarChar(100)
  note         String?
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now())    @map("created_at")
  updatedAt    DateTime  @updatedAt         @map("updated_at")

  estimateItems EstimateItem[]
  impositions   ImpositionSuggestion[]

  @@map("papers")
}

model PrintPriceMaster {
  id         Int       @id @default(autoincrement())
  colorType  ColorType @map("color_type")
  minSheets  Int       @map("min_sheets")
  maxSheets  Int?      @map("max_sheets")
  unitPrice  Decimal   @db.Decimal(10, 4) @map("unit_price")
  note       String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt      @map("updated_at")

  @@map("print_price_masters")
}

model ProcessingPriceMaster {
  id            Int          @id @default(autoincrement())
  processType   ProcessType  @map("process_type")
  productType   ProductType? @map("product_type")
  threshold     Int
  fixedPrice    Decimal      @db.Decimal(10, 2) @map("fixed_price")
  coeffA        Decimal?     @db.Decimal(10, 6) @map("coeff_a")
  coeffB        Decimal?     @db.Decimal(10, 4) @map("coeff_b")
  perSheetPrice Decimal?     @db.Decimal(10, 4) @map("per_sheet_price")
  note          String?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt      @map("updated_at")

  @@map("processing_price_masters")
}

model DieMold {
  id              Int       @id @default(autoincrement())
  moldCode        String    @unique @db.VarChar(30) @map("mold_code")
  moldType        MoldType  @map("mold_type")
  widthMm         Decimal   @db.Decimal(7, 1) @map("width_mm")
  heightMm        Decimal   @db.Decimal(7, 1) @map("height_mm")
  faces           Int       @default(1)
  complexity      Int       @default(1)
  baseMoldCost    Decimal?  @db.Decimal(10, 2) @map("base_mold_cost")
  customerId      Int?      @map("customer_id")
  storageLocation String?   @db.VarChar(100) @map("storage_location")
  manufacturedAt  DateTime? @map("manufactured_at")
  note            String?
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")

  customer      Customer?      @relation(fields: [customerId], references: [id])
  estimateItems EstimateItem[]

  @@map("die_molds")
}

model OutsourceVendor {
  id           Int           @id @default(autoincrement())
  name         String        @db.VarChar(100)
  processTypes ProcessType[]
  contactName  String?       @db.VarChar(50) @map("contact_name")
  phone        String?       @db.VarChar(20)
  email        String?       @db.VarChar(100)
  address      String?
  rate         Decimal       @db.Decimal(5, 2) @default(100)
  note         String?
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt      @map("updated_at")

  estimateItems       EstimateItem[]
  estimateProcessings EstimateProcessing[]

  @@map("outsource_vendors")
}

model Customer {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  nameKana    String?  @db.VarChar(100) @map("name_kana")
  contactName String?  @db.VarChar(50)  @map("contact_name")
  email       String?  @db.VarChar(100)
  phone       String?  @db.VarChar(20)
  address     String?
  note        String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  estimates Estimate[]
  dieMolds  DieMold[]

  @@map("customers")
}

model SystemSetting {
  key         String   @id @db.VarChar(50)
  value       String
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ── ユーザー ─────────────────────────────────────────────────

model User {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(50)
  email        String    @unique @db.VarChar(100)
  passwordHash String    @map("password_hash")
  role         UserRole  @default(staff)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt      @map("updated_at")

  assignedEstimates Estimate[]      @relation("AssignedEstimates")
  createdEstimates  Estimate[]      @relation("CreatedEstimates")
  histories         EstimateHistory[]

  @@map("users")
}

// ── 見積もり ─────────────────────────────────────────────────

model Estimate {
  id             Int            @id @default(autoincrement())
  estimateNumber String         @unique @db.VarChar(20) @map("estimate_number")
  title          String         @db.VarChar(200)
  customerId     Int?           @map("customer_id")
  customerName   String         @db.VarChar(100) @map("customer_name")
  productType    ProductType    @map("product_type")
  category       String         @db.VarChar(50)
  status         EstimateStatus @default(draft)
  validUntil     DateTime?      @map("valid_until")
  overheadRate   Decimal        @db.Decimal(5, 2) @default(15) @map("overhead_rate")
  assignedTo     Int?           @map("assigned_to")
  note           String?
  createdBy      Int?           @map("created_by")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt      @map("updated_at")

  customer Customer? @relation(fields: [customerId], references: [id])
  assignee User?     @relation("AssignedEstimates", fields: [assignedTo], references: [id])
  creator  User?     @relation("CreatedEstimates",  fields: [createdBy],  references: [id])

  items     EstimateItem[]
  histories EstimateHistory[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("estimates")
}

model EstimateItem {
  id             Int         @id @default(autoincrement())
  estimateId     Int         @map("estimate_id")
  sortOrder      Int         @default(1)  @map("sort_order")
  itemName       String      @db.VarChar(200) @map("item_name")

  finishWidthMm  Decimal     @db.Decimal(7, 1) @map("finish_width_mm")
  finishHeightMm Decimal     @db.Decimal(7, 1) @map("finish_height_mm")

  paperId        Int?        @map("paper_id")
  paperName      String?     @db.VarChar(100)   @map("paper_name")
  paperWidthMm   Decimal?    @db.Decimal(7, 1)  @map("paper_width_mm")
  paperHeightMm  Decimal?    @db.Decimal(7, 1)  @map("paper_height_mm")
  paperUnitPrice Decimal?    @db.Decimal(10, 2) @map("paper_unit_price")

  faces          Int         @default(1)
  cuts           Int         @default(1)
  frontColors    Int         @default(4)  @map("front_colors")
  backColors     Int         @default(0)  @map("back_colors")
  coater         CoaterType  @default(none)
  colorType      ColorType   @default(process) @map("color_type")
  wasteRate      Decimal     @db.Decimal(5, 2) @default(15) @map("waste_rate")

  hasMold        Boolean     @default(false) @map("has_mold")
  moldId         Int?        @map("mold_id")
  moldComplexity Int?        @default(1)     @map("mold_complexity")

  outsourceVendorId Int?     @map("outsource_vendor_id")
  note              String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt      @map("updated_at")

  estimate        Estimate         @relation(fields: [estimateId],        references: [id], onDelete: Cascade)
  paper           Paper?           @relation(fields: [paperId],           references: [id])
  mold            DieMold?         @relation(fields: [moldId],            references: [id])
  outsourceVendor OutsourceVendor? @relation(fields: [outsourceVendorId], references: [id])

  processings EstimateProcessing[]
  quantities  EstimateQuantity[]
  impositions ImpositionSuggestion[]

  @@index([estimateId])
  @@map("estimate_items")
}

model EstimateProcessing {
  id                 Int         @id @default(autoincrement())
  estimateItemId     Int         @map("estimate_item_id")
  processType        ProcessType @map("process_type")
  isOutsourced       Boolean     @default(false)  @map("is_outsourced")
  outsourceVendorId  Int?        @map("outsource_vendor_id")
  outsourceUnitPrice Decimal?    @db.Decimal(10, 2) @map("outsource_unit_price")
  note               String?
  sortOrder          Int         @default(1) @map("sort_order")

  estimateItem    EstimateItem     @relation(fields: [estimateItemId],    references: [id], onDelete: Cascade)
  outsourceVendor OutsourceVendor? @relation(fields: [outsourceVendorId], references: [id])

  @@index([estimateItemId])
  @@map("estimate_processings")
}

model EstimateQuantity {
  id             Int      @id @default(autoincrement())
  estimateItemId Int      @map("estimate_item_id")
  quantity       Int

  actualSheets   Decimal? @db.Decimal(10, 2) @map("actual_sheets")
  wasteSheets    Decimal? @db.Decimal(10, 2) @map("waste_sheets")
  totalSheets    Decimal? @db.Decimal(10, 2) @map("total_sheets")
  passes         Decimal? @db.Decimal(10, 2)

  paperCost      Decimal  @db.Decimal(12, 2) @default(0) @map("paper_cost")
  plateCost      Decimal  @db.Decimal(12, 2) @default(0) @map("plate_cost")
  printCost      Decimal  @db.Decimal(12, 2) @default(0) @map("print_cost")
  inkCost        Decimal  @db.Decimal(12, 2) @default(0) @map("ink_cost")
  cuttingCost    Decimal  @db.Decimal(12, 2) @default(0) @map("cutting_cost")
  pressCost      Decimal  @db.Decimal(12, 2) @default(0) @map("press_cost")
  ppCost         Decimal  @db.Decimal(12, 2) @default(0) @map("pp_cost")
  embossCost     Decimal  @db.Decimal(12, 2) @default(0) @map("emboss_cost")
  foilCost       Decimal  @db.Decimal(12, 2) @default(0) @map("foil_cost")
  laminationCost Decimal  @db.Decimal(12, 2) @default(0) @map("lamination_cost")
  corrugatedCost Decimal  @db.Decimal(12, 2) @default(0) @map("corrugated_cost")
  thomsonCost    Decimal  @db.Decimal(12, 2) @default(0) @map("thomson_cost")
  bindingCost    Decimal  @db.Decimal(12, 2) @default(0) @map("binding_cost")
  packingCost    Decimal  @db.Decimal(12, 2) @default(0) @map("packing_cost")
  deliveryCost   Decimal  @db.Decimal(12, 2) @default(0) @map("delivery_cost")
  outsourceCost  Decimal  @db.Decimal(12, 2) @default(0) @map("outsource_cost")

  subtotal       Decimal  @db.Decimal(12, 2) @default(0)
  overheadAmount Decimal  @db.Decimal(12, 2) @default(0) @map("overhead_amount")
  total          Decimal  @db.Decimal(12, 2) @default(0)
  unitPrice      Decimal? @db.Decimal(12, 4) @map("unit_price")

  isSelected     Boolean  @default(false) @map("is_selected")
  calculatedAt   DateTime?               @map("calculated_at")
  createdAt      DateTime @default(now()) @map("created_at")

  estimateItem EstimateItem @relation(fields: [estimateItemId], references: [id], onDelete: Cascade)

  @@index([estimateItemId])
  @@map("estimate_quantities")
}

model EstimateHistory {
  id           Int      @id @default(autoincrement())
  estimateId   Int      @map("estimate_id")
  version      Int
  snapshotJson Json     @map("snapshot_json")
  changedById  Int?     @map("changed_by")
  changeNote   String?  @db.VarChar(200) @map("change_note")
  createdAt    DateTime @default(now()) @map("created_at")

  estimate  Estimate @relation(fields: [estimateId],  references: [id], onDelete: Cascade)
  changedBy User?    @relation(fields: [changedById], references: [id])

  @@index([estimateId])
  @@map("estimate_histories")
}

model ImpositionSuggestion {
  id             Int      @id @default(autoincrement())
  estimateItemId Int      @map("estimate_item_id")
  paperId        Int?     @map("paper_id")
  paperName      String?  @db.VarChar(100) @map("paper_name")
  facesH         Int      @map("faces_h")
  facesV         Int      @map("faces_v")
  totalFaces     Int      @map("total_faces")
  rotated        Boolean  @default(false)
  totalSheets    Decimal? @db.Decimal(10, 2) @map("total_sheets")
  paperCost      Decimal? @db.Decimal(12, 2) @map("paper_cost")
  patternLabel   String   @db.VarChar(20) @map("pattern_label")
  isSelected     Boolean  @default(false) @map("is_selected")
  createdAt      DateTime @default(now()) @map("created_at")

  estimateItem EstimateItem @relation(fields: [estimateItemId], references: [id], onDelete: Cascade)
  paper        Paper?       @relation(fields: [paperId],        references: [id])

  @@map("imposition_suggestions")
}
